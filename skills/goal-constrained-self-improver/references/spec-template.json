{
  "goal": "在不改变外部接口的前提下，修复 XXX 并让关键用例全部通过",
  "constraints": [
    "不修改 public API 的函数签名",
    "不删除现有测试",
    "不引入新的第三方依赖"
  ],
  "default_timeout_sec": 600,
  "max_iterations": 12,
  "auto_modify": {
    "command": "python3 scripts/auto_fix.py --spec {spec_q} --iteration {iteration}",
    "timeout_sec": 900,
    "stop_on_failure": false
  },
  "checks": [
    {
      "name": "unit_tests",
      "command": "pytest -q",
      "hard_gate": true
    },
    {
      "name": "lint",
      "command": "ruff check .",
      "hard_gate": true
    },
    {
      "name": "type_check",
      "command": "mypy .",
      "hard_gate": false
    }
  ]
}
